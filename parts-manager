<!DOCTYPE html>
<html>
<head>
  <title>Parts Selector</title>
  <style>
    body { font-family: Arial; margin: 20px; }
    input { margin-bottom: 10px; padding: 5px; width: 300px; }
    .container { display: flex; gap: 40px; }
    ul { list-style: none; padding: 0; }
    li { margin: 5px 0; }
  </style>
</head>
<body>

<h2>Parts Selector</h2>

<input type="text" id="searchBox" placeholder="Search part number OR description..." onkeyup="filterList()" />

<div class="container">
  <div>
    <h3>All Items</h3>
    <ul id="itemList"></ul>
  </div>

  <div>
    <h3>Remaining Items (Not Selected)</h3>
    <ul id="remainingList"></ul>
  </div>
</div>

<script>
  const items = [
    { part: "A123", desc: "Hydraulic Pump" },
    { part: "B456", desc: "Oil Filter" },
    { part: "C789", desc: "Air Compressor" },
    { part: "D012", desc: "Fuel Injector" },
    { part: "E345", desc: "Cooling Fan" }
  ];

  const selected = new Set();

  function renderList(filter = "") {
    const listEl = document.getElementById("itemList");
    listEl.innerHTML = "";

    items
      .filter(item =>
        item.part.toLowerCase().includes(filter) ||
        item.desc.toLowerCase().includes(filter)
      )
      .forEach(item => {
        const li = document.createElement("li");

        const checkbox = document.createElement("input");
        checkbox.type = "checkbox";
        checkbox.checked = selected.has(item.part);

        checkbox.onchange = () => {
          if (checkbox.checked) {
            selected.add(item.part);
          } else {
            selected.delete(item.part);
          }
          renderRemaining();
        };

        li.appendChild(checkbox);
        li.append(` ${item.part} - ${item.desc}`);
        listEl.appendChild(li);
      });
  }

  function renderRemaining() {
    const remainingEl = document.getElementById("remainingList");
    remainingEl.innerHTML = "";

    items
      .filter(item => !selected.has(item.part))
      .forEach(item => {
        const li = document.createElement("li");
        li.textContent = `${item.part} - ${item.desc}`;
        remainingEl.appendChild(li);
      });
  }

  function filterList() {
    const value = document.getElementById("searchBox").value.toLowerCase();
    renderList(value);
  }

  // Initial render
  renderList();
  renderRemaining();
</script>

</body>
</html>
